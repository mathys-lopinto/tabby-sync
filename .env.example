# Copy to .env and fill in the values.
# The backend auto-loads .env on startup (python-dotenv).

# ---- Required ----------------------------------------------------------

# Database connection string. Driver must be installed.
#   MySQL/MariaDB: mysql://USER:PASS@HOST:3306/DBNAME
#   Postgres:      postgres://USER:PASS@HOST:5432/DBNAME
#   SQLite (dev):  sqlite:////absolute/path/to/db.sqlite3
DATABASE_URL=mysql://root:123@db/tabby

# Secret used for session/CSRF signing. Generate with:
#   openssl rand -hex 32
DJANGO_SECRET_KEY=change-me

# ---- Optional ----------------------------------------------------------

# Django debug mode. Never enable in production.
DEBUG=False

# CORS / CSRF — only needed if a browser frontend hits the API from another
# origin. The Tabby desktop client does NOT need these.
#FRONTEND_URL=https://tabby.example.com
#CORS_EXTRA_URL=https://other.example.com
#BACKEND_URL=https://sync.example.com

# ---- Container-only ----------------------------------------------------

# Port gunicorn binds to inside the container.
PORT=80

# Number of gunicorn workers. Rule of thumb: 2 * CPU + 1.
WEB_CONCURRENCY=4

# dockerize waits for dependencies before starting (used by start.sh).
DOCKERIZE_ARGS=-wait tcp://db:3306 -timeout 60s
