# Copy to .env and fill in the values.
# Both the backend (python-dotenv) and docker compose read this file.

# ---- Database ---------------------------------------------------------
#
# The backend is DB-agnostic. Pick one backend and set DATABASE_URL
# accordingly. The docker compose stack uses Postgres.
#
# SQLite (dev, no driver needed — sqlite3 is in the stdlib):
#   DATABASE_URL=sqlite:////absolute/path/to/dev.db
#
# Postgres (default, driver installed by default):
#   DATABASE_URL=postgres://USER:PASS@HOST:5432/DBNAME
#
# MySQL / MariaDB (driver is optional — install with
#   `poetry install --extras mysql`):
#   DATABASE_URL=mysql://USER:PASS@HOST:3306/DBNAME
#
# The variables below are consumed by docker compose to build both
# POSTGRES_* for the db service and DATABASE_URL for the app.

DB_NAME=tabby
DB_USER=tabby
DB_PASSWORD=change-me-please

# ---- Django -----------------------------------------------------------

# Generate with: openssl rand -hex 32
DJANGO_SECRET_KEY=change-me

# Never enable in production.
DEBUG=False

# ---- Runtime (optional) -----------------------------------------------

# Host port exposed by docker compose (container always listens on 80).
HOST_PORT=9090

# gunicorn workers. Rule of thumb: 2 * CPU + 1.
WEB_CONCURRENCY=4

# ---- CORS / CSRF (optional, only if a browser frontend calls the API) -

#FRONTEND_URL=https://tabby.example.com
#CORS_EXTRA_URL=https://other.example.com
#BACKEND_URL=https://sync.example.com
